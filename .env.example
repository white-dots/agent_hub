# AgentHub Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API Key (for embeddings if needed)
# OPENAI_API_KEY=sk-...

# Optional: Model configuration
# AGENTHUB_DEFAULT_MODEL=claude-sonnet-4-20250514
# AGENTHUB_OPUS_MODEL=claude-opus-4-0-20250115
# AGENTHUB_HAIKU_MODEL=claude-haiku-3-5-20241022

# Optional: Limits
# AGENTHUB_MAX_TOKENS_PER_SESSION=100000
# AGENTHUB_MAX_CONTEXT_PER_AGENT=50000
# AGENTHUB_DEFAULT_MAX_TOKENS=4096

# Optional: Storage paths
# AGENTHUB_SESSION_STORAGE_PATH=./sessions
# AGENTHUB_CONTEXT_CACHE_PATH=./context_cache

# Optional: Database connection (for DBAgent)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
